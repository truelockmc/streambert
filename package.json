{
  "name": "streambert",
  "version": "2.1.0",
  "description": "Streambert Desktop App",
  "author": {
    "name": "truelockmc",
    "email": "anonyson@proton.me"
  },
  "license": "GPL-3.0",
  "main": "index.js",
  "private": false,
  "scripts": {
    "dev": "vite build --watch",
    "start": "vite build && electron .",
    "dist": "vite build && electron-builder",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "terser": "^5.46.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.truelockmc.streambert",
    "productName": "Streambert",
    "asar": true,
    "compression": "normal",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "src/ipc/**/*",
      "index.js",
      "preload.js",
      "package.json",
      "!**/*.map",
      "!**/*.md",
      "!**/*.ts",
      "!**/*.d.ts",
      "!**/node_modules/.cache/**",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,changelog.md,CHANGES,LICENCE,LICENSE}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples,benchmark,benchmarks}/**",
      "!**/node_modules/.bin/**",
      "!**/node_modules/*/*.d.ts",
      "!**/{.eslintrc,.babelrc,.editorconfig,.nycrc}",
      "!**/{jest.config,jest.config.js,jest.config.ts}",
      "!**/node_modules/*/docs/**",
      "!**/node_modules/vite/**",
      "!**/node_modules/@vitejs/**",
      "!**/node_modules/terser/**",
      "!**/node_modules/rollup/**",
      "!**/node_modules/esbuild/**",
      "!**/node_modules/@esbuild/**",
      "!**/node_modules/@rollup/**"
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createStartMenuShortcut": true,
      "selectPerMachineByDefault": false,
      "license": "LICENSE",
      "uninstallDisplayName": "Uninstall Streambert",
      "installerSidebar": "public/installer-sidebar.bmp"
    },
    "win": {
      "icon": "public/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "public/icon.png"
    },
    "electronLanguages": [
      "en-US",
      "de"
    ],
    "asarUnpack": [
      "src/styles/fonts/**"
    ]
  }
}
